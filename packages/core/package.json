{
  "name": "@cnstra/core",
  "version": "2.0.1",
  "description": "Embeddable workflow/orchestration engine for TypeScript: deterministic runs over a typed neuron graph (in-memory, zero dependencies).",
  "keywords": [
    "neural-network",
    "event-flow",
    "reactive",
    "dependency-injection",
    "neuron",
    "synapse",
    "axon",
    "dendrite",
    "workflow",
    "workflow-engine",
    "orchestrator",
    "orchestration",
    "job-orchestration",
    "background-jobs",
    "etl",
    "pipeline",
    "retries",
    "retry",
    "saga",
    "bullmq",
    "typescript",
    "node",
    "browser"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abaikov/cnstra.git"
  },
  "bugs": {
    "url": "https://github.com/abaikov/cnstra/issues"
  },
  "homepage": "https://github.com/abaikov/cnstra#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run test && npm run test:types && npm run build",
    "test": "jest",
    "test:types": "npm run build:types",
    "examples": "tsx examples/run-examples.ts"
  },
  "files": [
    "dist"
  ],
  "author": "Andrei Baikov <abaikov23@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
