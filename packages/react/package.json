{
  "name": "@cnstra/react",
  "version": "1.0.2",
  "description": "React bindings for CNStra workflow/orchestration engine (provider + hooks).",
  "keywords": [
    "react",
    "neural-network",
    "event-flow",
    "reactive",
    "context",
    "hooks",
    "workflow",
    "orchestration",
    "orchestrator"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@cnstra/core": "2.0.1",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "18.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsup": "8.5.1",
    "typescript": "5.8.3"
  },
  "author": "Andrei Baikov <abaikov23@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
